<% if (title) { %>
  <h1><%= title %></h1>
<% } %>

<%- grid %>

<% if (typeof errors !== 'undefined' && errors.length > 0) { %>
  <div class="error-message">
    <ul>
      <% errors.forEach(error => { %>
        <li><%= error.message %></li>
      <% }) %>
    </ul>
  </div>
<% } %>

<!-- Reviews Section -->
<div class="reviews-section">
  <h2>Customer Reviews</h2>

  <% if (reviews && reviews.length > 0) { %>
    <% reviews.forEach(review => { %>
      <div class="review">
        <div class="review-header">
          <strong><%= review.account_firstname %> <%= review.account_lastname %></strong>
          <span class="review-date"><%= new Date(review.review_date).toLocaleDateString() %></span>
        </div>
        <p class="review-text"><%= review.review_text %></p>
        <% if (locals.accountData && (locals.accountData.account_id === review.account_id || locals.accountData.account_type === 'Admin')) { %>
          <form action="/review/delete/<%= review.review_id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this review?')" style="display: inline; margin: 0; padding: 0; border: none; background: none;">
            <input type="hidden" name="inv_id" value="<%= inv_id %>">
            <button type="submit" class="delete-review-btn">Delete</button>
          </form>
        <% } %>
      </div>
    <% }) %>
  <% } else { %>
    <p>No reviews yet. Be the first to leave a review!</p>
  <% } %>

  <% if (locals.loggedin) { %>
    <div class="add-review">
      <h3>Add Your Review</h3>
      <form action="/review/add" method="POST">
        <input type="hidden" name="inv_id" value="<%= inv_id %>">
        <textarea name="review_text" rows="4" placeholder="Write your review here..." required minlength="10" maxlength="1000"><%= typeof review_text !== 'undefined' ? review_text : '' %></textarea>
        <button type="submit">Submit Review</button>
      </form>
    </div>
  <% } else { %>
    <p><a href="/account/login">Log in</a> to leave a review.</p>
  <% } %>
</div>