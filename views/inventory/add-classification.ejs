<h1>Add Classification</h1>

<% if (errors) { %>
  <ul>
    <% errors.forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<form action="/inv/add-classification" method="post">
  <label>Classification Name</label>
  <input 
    type="text" 
    name="classification_name"
    required
    pattern="^[A-Za-z0-9]+$"
  >

  <button type="submit">Add</button>
</form>